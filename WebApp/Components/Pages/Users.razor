@page "/users"
@rendermode InteractiveServer

<h3>ניהול משתמשים</h3>
<p></p>

@* בניית טבלה להצגת נתוני המשתמשים מתוך מסד הנתונים *@
<table class="table table-success table-bordered table-striped table-hover table-sm">
    <thead>
        @* שורת הכותרת של הטבלה *@
        <tr>
            <th>מזהה</th>
            <th>שם מלא</th>
            <th>שם משתמש</th>
            <th>אימייל</th>
            <th>עריכה</th>
            <th>מחיקה</th>
        </tr>
    </thead>
    <tbody>
        @* לולאה העוברת על רשימת המשתמשים ומייצרת שורה עבור כל עצם ברשימה *@
        @foreach (User item in users)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FullName</td>
                <td>@item.UserName</td>
                <td>@item.Email</td>
                @* ניווט לדף עריכה עם שליחת המזהה של המשתמש הספציפי *@
                <td><a class="btn btn-warning" href="/edit-user/@item.Id">עריכה</a></td>
                @* הפעלת פעולת מחיקה בלחיצה, תוך שליחת המזהה כפרמטר *@
                <td><button class="btn btn-danger" @onclick="() => DeleteUser(item.Id)">מחיקה</button></td>
            </tr>
        }
    </tbody>
</table>

<hr>

@* כפתור מעבר לדף הוספת משתמש חדש *@
<a class="btn btn-primary" href="/add-user">הוסף משתמש חדש +</a>

@code {
    // הגדרת רשימה שתכיל את עצמי המשתמשים שיישלפו מהשירות
    List<User> users = new List<User>();

    // יצירת עצם של השירות המטפל בלוגיקה ובגישה למסד הנתונים
    UserService userService = new UserService();

    // פעולה המתבצעת באופן אוטומטי עם טעינת הדף
    protected override void OnInitialized()
    {
        // שליפת כל המשתמשים מהמסד ועדכון הרשימה המקושרת לתצוגה
        users = userService.GetAllUsers();
    }

    // פעולה המבצעת מחיקה של משתמש לפי המזהה שלו
    void DeleteUser(int id)
    {
        // קריאה לפעולה בשירות המבצעת את פקודת המחיקה במסד הנתונים
        userService.DeleteUser(id);

        // טעינה מחדש של הרשימה המעודכנת כדי שהשינוי ייראה מיד על המסך
        users = userService.GetAllUsers();
    }
}