@page "/edit-user/{UserId:int}"
@rendermode InteractiveServer
@inject NavigationManager Nav

<h3>עריכת משתמש</h3>

@* שדות קלט לעריכת פרטי המשתמש - מקושרים לעצם המשתמש *@

<div class="mb-3">
    <label>שם מלא:</label>
    <input class="form-control" @bind-value="user.FullName" />
</div>

<div class="mb-3">
    <label>שם משתמש:</label>
    <input class="form-control" @bind-value="user.UserName" />
</div>

<div class="mb-3">
    <label>אימייל:</label>
    <input class="form-control" @bind-value="user.Email" />
</div>

<div class="mb-3">
    <label>סיסמה:</label>
    <input type="password" class="form-control" @bind-value="user.Password" />
</div>

<button class="btn btn-primary" @onclick="UpdateUser">עדכן משתמש</button>

@code {
    [Parameter]
    // הגדרת פרמטר המקבל את המזהה מכתובת הדף (למשל מהספרה שבסוף הכתובת)
    public int UserId { get; set; }

    // יצירת עצם משתמש שיכיל את הנתונים שיוצגו וייערכו בדף
    User user = new User();

    // יצירת עצם של השירות המטפל בלוגיקה של המשתמשים
    UserService userService = new UserService();

    // פעולה המתבצעת באופן אוטומטי ברגע שהדף נטען בדפדפן
    protected override void OnInitialized()
    {
        // שליפת נתוני המשתמש מהמסד בעזרת השירות לפי המזהה שהתקבל
        user = userService.GetUserById(UserId);

        // בדיקה: אם לא נמצא משתמש בבסיס הנתונים, נאתחל עצם משתמש ריק כדי למנוע קריסה של התצוגה
        if (user == null)
        {
            user = new User();
        }
    }

    public void UpdateUser()
    {
        // שליחת העצם המעודכן לשירות לצורך עדכון בסיס הנתונים
        userService.UpdateUser(user);

        // ניווט חזרה לדף רשימת המשתמשים לאחר סיום העדכון
        Nav.NavigateTo("/users");
    }
}